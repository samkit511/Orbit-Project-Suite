        "express": "^4.21.1",
        "express-rate-limit": "^8.5.1",
        "helmet": "^8.1.0",
        "hpp": "^0.2.3",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "nodemon": "^3.1.7",
        "prisma": "^5.22.0"
    }
}
